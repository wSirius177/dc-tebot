# Discord 机器人令牌
DISCORD_TOKEN=你的Discord机器人令牌

# 监听的 Discord 频道 ID（整数）
DISCORD_CHANNEL_ID=123456789012345678

# Telegram 机器人令牌
TELEGRAM_BOT_TOKEN=你的Telegram机器人令牌

# 接收消息的 Telegram 群组 ID（以 -100 开头）
TELEGRAM_CHAT_ID=-1001234567890

# 代理服务器地址（可选，留空则不使用代理）
PROXY_URL=http://127.0.0.1:7890

# 补发消息间隔秒数（可选，默认 1.0）
BACKFILL_DELAY=1.0

# ── 监控上传功能配置（可选） ──

# 要监控并自动上传的本地文件夹绝对路径（例如：D:\other_project\images）
# 留空或不配置此项则默认不开启监控上传功能
MONITOR_FOLDER_PATH=

# 扫描文件夹的新文件的时间间隔（秒），默认 60 秒
MONITOR_INTERVAL=60

# 上传文件指定的 Telegram 群组 ID
# 若留空，则默认使用上面的 TELEGRAM_CHAT_ID
MONITOR_TG_CHAT_ID=
